# PT Dashboard — local environment overrides
# Copy to `.env` and fill in real values; never commit secrets.

# HTTP port (default 8081)
HTTP_PORT=8081

# PostgreSQL (used starting PTD-3)
QUARKUS_DATASOURCE_USERNAME=ptdashboard
QUARKUS_DATASOURCE_PASSWORD=QUA...oard

# Reactive URL — used by Hibernate Reactive Panache (PTD-5+). Leave as is
# for local dev when Postgres is reachable on 5432.
QUARKUS_DATASOURCE_REACTIVE_URL=postgresql://localhost:5432/ptdashboard

# JDBC URL — used by Flyway (PTD-3). Leave BLANK in dev to keep Flyway
# disabled; set to a real JDBC URL (e.g. `jdbc:postgresql://localhost:5432/ptdashboard`)
# to apply V1__init.sql at startup.
QUARKUS_DATASOURCE_JDBC_URL=
QUARKUS_FLYWAY_MIGRATE_AT_START=false

# Firebase (used starting PTD-4 — required to enable auth on protected paths)
# Both must be set; if either is blank, FirebaseAppLifecycle logs a warning at boot
# and the FirebaseAuthFilter rejects every protected request with 401.
# Service account JSON must NEVER be committed to the repo.
FIREBASE_PROJECT_ID=pt-dashboard-dev
FIREBASE_SERVICE_ACCOUNT_PATH=/absolute/path/to/your-firebase-adminsdk-xxxxx.json