# Maven
target/
.mvn/timing.properties
# NOTE: maven-wrapper.jar MUST be tracked in git so CI can run `./mvnw`.
# Older Maven Wrapper bootstrappers re-download this jar, but newer ones
# expect to find it locally to avoid first-run network on CI runners.

# IDE
.idea/
*.iml
*.ipr
*.iws
.vscode/
.project
.classpath
.settings/

# OS
.DS_Store
Thumbs.db

# Quarkus dev / build artifacts
*.log
*.pid

# Local secrets / env overrides — never commit
.env
.env.local
.env.*.local

# Firebase service-account JSON (must NEVER be committed)
*-firebase-adminsdk-*.json
firebase-service-account*.json